---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <section class="w-full bg-neutral-950 border-t border-neutral-800 flex-1 flex items-center justify-center" style="min-height: calc(100vh - 13rem);">
    <div class="max-w-2xl mx-auto px-6 py-10 w-full">
      <div class="flex flex-col items-center text-center">
        <!-- 404 number -->
        <div class="relative mb-8">
          <p class="text-[10rem] md:text-[14rem] font-heading font-bold text-neutral-900 leading-none select-none">404</p>
        </div>
        <!-- Heading -->
        <h1 class="text-neutral-100 text-3xl md:text-4xl font-heading leading-tight mb-4">sh*t's broke</h1>
        <!-- Description -->
        <p class="text-neutral-500 text-sm leading-relaxed max-w-md mb-10">the page you were looking for isn't here.<br> maybe it was never here.<br> maybe it was, and decided to leave.<br> these pages have free wills and i'm not about to tell them what to do.</p>
        
      </div>
    </div>
  </section>
</Layout>
