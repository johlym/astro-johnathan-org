---
import Layout from '../layouts/Layout.astro'
import { getPosts } from '../lib/payload'
import { getMdPosts } from '../lib/mdposts'

const LIMIT = 5

type RecentPost = { slug: string; title: string; date: Date; excerpt?: string }

let recentPosts: RecentPost[] = []

try {
  const { docs } = await getPosts(1, LIMIT)
  recentPosts = docs.map((p) => ({
    slug: p.slug,
    title: p.title,
    date: new Date(p.createdAt),
    excerpt: p.excerpt,
  }))
} catch {
  // Payload unavailable — will fill entirely from MD
}

if (recentPosts.length < LIMIT) {
  try {
    const mdPosts = await getMdPosts()
    const needed = LIMIT - recentPosts.length
    const mdFill = mdPosts.slice(0, needed).map((e) => ({
      slug: e.slug,
      title: e.data.title,
      date: e.data.date,
      excerpt: e.data.excerpt ?? e.data.description,
    }))
    recentPosts = [...recentPosts, ...mdFill]
  } catch {
    // fallback
  }
}
---

<Layout>
  {recentPosts.length > 0 && (
    <section>
      <h2 class="text-2xl font-semibold mb-6">Recent Posts</h2>
      <div class="space-y-8">
        {recentPosts.map((post) => (
          <article class="group">
            <a href={`/blog/${post.slug}`} class="no-underline block">
              <h3 class="text-xl font-semibold text-black dark:text-white group-hover:text-accent dark:group-hover:text-accent-light transition-colors">
                {post.title}
              </h3>
            </a>
            <time
              class="text-sm text-gray-600 dark:text-gray-300 mt-1 block"
              datetime={post.date.toISOString()}
            >
              {post.date.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            {post.excerpt && (
              <p class="mt-2 text-gray-600 dark:text-gray-300">{post.excerpt}</p>
            )}
          </article>
        ))}
      </div>
      <div class="mt-8">
        <a href="/blog" class="text-accent dark:text-accent-light font-medium">
          View all posts &rarr;
        </a>
      </div>
    </section>
  )}
</Layout>
