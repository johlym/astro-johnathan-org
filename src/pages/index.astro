---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import Hero from '../components/homepage/Hero.astro'
import PostCard from '../components/homepage/PostCard.astro'
import { getPosts } from '../lib/payload'
import { getMdPosts } from '../lib/mdposts'

const LIMIT = 5

type RecentPost = { slug: string; title: string; date: Date; excerpt?: string; category?: string }

let recentPosts: RecentPost[] = []

try {
  const { docs } = await getPosts(1, LIMIT)
  recentPosts = docs.map((p) => ({
    slug: p.slug,
    title: p.title,
    date: new Date(p.createdAt),
    excerpt: p.excerpt,
    category:
      p.category && typeof p.category === 'object' && 'title' in p.category
        ? (p.category as { title: string }).title
        : undefined,
  }))
} catch {
  // Payload unavailable — will fill entirely from MD
}

if (recentPosts.length < LIMIT) {
  try {
    const mdPosts = await getMdPosts()
    const needed = LIMIT - recentPosts.length
    const mdFill = mdPosts.slice(0, needed).map((e) => ({
      slug: e.slug,
      title: e.data.title,
      date: e.data.date,
      excerpt: e.data.excerpt ?? e.data.description,
      category: e.data.category,
    }))
    recentPosts = [...recentPosts, ...mdFill]
  } catch {
    // fallback
  }
}
---

<Layout>
  <Hero />
  {recentPosts.length > 0 && (
    <section class="w-full bg-neutral-950 pt-20 pb-6 border-t border-neutral-800">
      <div class="max-w-3xl mx-auto px-6">
        <div class="flex items-center justify-between mb-12">
          <h2 class="text-neutral-100 text-xs uppercase tracking-widest font-heading">Latest Posts</h2>
          <span class="text-neutral-700 text-xs">{new Date().getFullYear()}</span>
        </div>
        {recentPosts.map((post) => (
          <PostCard post={post} />
        ))}
        <div class="pt-8 mt-4">
          <a href="/blog" class="inline-flex items-center gap-2 text-lime-400 text-xs uppercase tracking-widest hover:gap-4 transition-all font-heading no-underline">
            View all posts
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"></path>
            </svg>
          </a>
        </div>
      </div>
    </section>
  )}
</Layout>
