---
export const prerender = false

import Layout from '../layouts/Layout.astro'
import ArticleHeader from '../components/posts/ArticleHeader.astro'
import RichText from '../components/RichText.astro'
import { getPage } from '../lib/payload'

const { slug } = Astro.params

if (!slug) return Astro.redirect('/')

let page
try {
  const result = await getPage(slug)
  page = result.docs[0] ?? null
} catch {
  page = null
}

if (!page) return Astro.redirect('/404')
---

<Layout title={page.title} description={page.excerpt}>
  <ArticleHeader
    title={page.title}
    excerpt={page.excerpt}
  />

  <section class="content-container w-full bg-neutral-950 pb-16">
    <div class="max-w-3xl mx-auto px-6">
      <RichText content={page.body} class="rich-text" />
    </div>
  </section>
</Layout>
