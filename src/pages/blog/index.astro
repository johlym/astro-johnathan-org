---
export const prerender = false

import Layout from '../../layouts/Layout.astro'
import { getPosts } from '../../lib/payload'
import { getMdPosts } from '../../lib/mdposts'

const pageParam = Astro.url.searchParams.get('page')
const page = Math.max(1, parseInt(pageParam || '1', 10) || 1)
const limit = 10

// ── CMS posts (always fetch to get totalDocs, even if page > cmsPages) ───────
let cmsResult: Awaited<ReturnType<typeof getPosts>> = { docs: [], totalDocs: 0, limit: 10, totalPages: 0, page: 1, hasPrevPage: false, hasNextPage: false, prevPage: null, nextPage: null }
try {
  cmsResult = await getPosts(page, limit)
} catch (err) {
  console.error('[blog] getPosts failed:', err)
}
const cmsTotalDocs = cmsResult.totalDocs
const cmsTotalPages = Math.ceil(cmsTotalDocs / limit)
// How many CMS posts appear on the last CMS page
const cmsLastPageCount = cmsTotalDocs > 0 ? (cmsTotalDocs % limit || limit) : 0
// How many MD posts fill the remainder of that last CMS page
const mdFillCount = cmsLastPageCount > 0 && cmsLastPageCount < limit
  ? limit - cmsLastPageCount
  : 0

// ── Legacy MD posts (compiled at build time — no network) ────────────────────
let allMdPosts: Awaited<ReturnType<typeof getMdPosts>> = []
try {
  allMdPosts = await getMdPosts()
} catch (err) {
  console.error('[blog] getMdPosts failed:', err)
}
console.log(`[blog] MD posts loaded: ${allMdPosts.length}`)
const mdTotal = allMdPosts.length

// ── Combined total pages ──────────────────────────────────────────────────────
const remainingMd = Math.max(0, mdTotal - mdFillCount)
const totalPagesAll = cmsTotalPages + Math.ceil(remainingMd / limit)

// ── Build the list of posts for the current page ──────────────────────────────
type UnifiedPost = {
  slug: string
  title: string
  date: Date
  excerpt?: string
  category?: string
  source: 'cms' | 'md'
}

let pagePosts: UnifiedPost[] = []

if (page <= cmsTotalPages) {
  // CMS territory (last CMS page may have MD fill)
  const cmsEntries: UnifiedPost[] = cmsResult.docs.map((p) => ({
    slug: p.slug,
    title: p.title,
    date: new Date(p.createdAt),
    excerpt: p.excerpt,
    category:
      p.category && typeof p.category === 'object' && 'title' in p.category
        ? (p.category as { title: string }).title
        : undefined,
    source: 'cms',
  }))

  if (page === cmsTotalPages && mdFillCount > 0) {
    const mdFill: UnifiedPost[] = allMdPosts.slice(0, mdFillCount).map((e) => ({
      slug: e.slug,
      title: e.data.title,
      date: e.data.date,
      excerpt: e.data.excerpt ?? e.data.description,
      category: e.data.category,
      source: 'md',
    }))
    pagePosts = [...cmsEntries, ...mdFill]
  } else {
    pagePosts = cmsEntries
  }
} else {
  // Pure MD territory
  const mdStart = mdFillCount + (page - cmsTotalPages - 1) * limit
  pagePosts = allMdPosts.slice(mdStart, mdStart + limit).map((e) => ({
    slug: e.slug,
    title: e.data.title,
    date: e.data.date,
    excerpt: e.data.excerpt ?? e.data.description,
    category: e.data.category,
    source: 'md',
  }))
}

const hasPrev = page > 1
const hasNext = page < totalPagesAll
---

<Layout title="Blog">
  <section class="w-full bg-neutral-950 py-20 border-b border-neutral-800">
    <div class="max-w-3xl mx-auto px-6">
      <p class="text-lime-400 text-xs uppercase tracking-widest mb-4 font-heading">Archive</p>
      <h1 class="text-neutral-100 text-4xl font-heading leading-tight">Blog</h1>
    </div>
  </section>

  <section class="w-full bg-neutral-950 py-12">
    <div class="max-w-3xl mx-auto px-6">
      {pagePosts.length > 0 ? (
        <>
          {pagePosts.map((post, i) => (
            <article class={`group py-8 border-b border-neutral-900 hover:border-neutral-700 transition-colors${i === pagePosts.length - 1 ? ' border-b-0' : ''}`}>
              <a href={`/blog/${post.slug}`} class="no-underline block">
                <div class="flex items-start justify-between gap-8">
                  <div class="flex-1">
                    <p class="text-neutral-600 text-xs mb-3 font-heading">
                      {post.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                    </p>
                    <h2 class="text-neutral-100 text-lg mb-3 group-hover:text-lime-400 transition-colors font-heading">
                      {post.title}
                    </h2>
                    {post.excerpt && (
                      <p class="text-neutral-500 text-sm leading-relaxed">{post.excerpt}</p>
                    )}
                    {post.category && (
                      <div class="flex items-center gap-3 mt-4">
                        <span class="text-xs text-neutral-700 bg-neutral-900 px-2 py-1">{post.category}</span>
                      </div>
                    )}
                  </div>
                  <svg class="w-5 h-5 text-neutral-700 group-hover:text-lime-400 group-hover:translate-x-1 transition-all mt-6 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                    <path d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"></path>
                  </svg>
                </div>
              </a>
            </article>
          ))}

          {totalPagesAll > 1 && (
            <nav class="mt-12 flex items-center justify-between" aria-label="Pagination">
              {hasPrev ? (
                <a href={`/blog?page=${page - 1}`} class="text-lime-400 text-xs uppercase tracking-widest hover:underline transition-colors font-heading no-underline">
                  &larr; Newer
                </a>
              ) : (
                <span />
              )}
              <span class="text-neutral-600 text-xs font-heading">
                Page {page} of {totalPagesAll}
              </span>
              {hasNext ? (
                <a href={`/blog?page=${page + 1}`} class="text-lime-400 text-xs uppercase tracking-widest hover:underline transition-colors font-heading no-underline">
                  Older &rarr;
                </a>
              ) : (
                <span />
              )}
            </nav>
          )}
        </>
      ) : (
        <p class="text-neutral-500 text-sm">No posts yet.</p>
      )}
    </div>
  </section>
</Layout>
