---
import Layout from '../layouts/Layout.astro'
import Content from '../components/Content.astro'
import ArticleHeader from '../components/posts/ArticleHeader.astro'
import RichText from '../components/RichText.astro'
import { getPage } from '../lib/payload'
import RaindropIoLinks from '../components/RaindropIoLinks.astro'

let page
try {
  const result = await getPage('links')
  page = result.docs[0] ?? null
} catch {
  page = null
}

if (!page) return Astro.redirect('/404')
---

<Layout title={page.title} description={page.excerpt}>
  <ArticleHeader
    title={page.title}
    excerpt={page.excerpt}
  />

  <Content>
    <RichText content={page.body} class="rich-text" />
    <RaindropIoLinks />
  </Content>
</Layout>
