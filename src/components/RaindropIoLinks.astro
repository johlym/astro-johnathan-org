---
---

<div id="raindrop-links" aria-live="polite">
  <p class="text-gray-500 dark:text-gray-400 animate-pulse">Loading links…</p>
</div>

<script>
  function esc(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  function slugify(s: string): string {
    return s.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')
  }

  type Raindrop = { title: string; link: string; domain: string; tags: string[] }
  type Section = { title: string; links: Raindrop[] }

  async function loadLinks() {
    const container = document.getElementById('raindrop-links')
    if (!container) return

    try {
      const base = (import.meta.env.PUBLIC_PAYLOAD_API_URL as string ?? '').replace(/\/$/, '')
      const res = await fetch(`${base}/api/raindrop`)
      const sections: Section[] = await res.json()

      if (!sections.length) {
        container.innerHTML = '<p class="text-gray-500 dark:text-gray-400">No links available.</p>'
        return
      }

      const nav = sections
        .map(
          (s) =>
            `<a href="#${slugify(s.title)}" class="text-accent dark:text-accent-light hover:underline">${esc(s.title)}</a>`,
        )
        .join('')

      const sectionsHtml = sections
        .map((section) => {
          const items = section.links
            .map((link) => {
              const tags = link.tags.length > 0 ? ` (${esc(link.tags.join(', '))})` : ''
              return `<li>
                <a href="${esc(link.link)}" target="_blank" rel="noopener noreferrer"
                  class="font-medium text-accent dark:text-accent-light hover:underline">${esc(link.title)}</a>
                <div class="text-sm text-gray-600 dark:text-gray-400">${esc(link.domain)}${tags}</div>
              </li>`
            })
            .join('')
          return `<section id="${slugify(section.title)}" class="mb-10">
            <h2 class="text-xl font-semibold mb-4 border-b border-gray-200 dark:border-gray-700 pb-2">${esc(section.title)}</h2>
            <ul class="space-y-4">${items}</ul>
          </section>`
        })
        .join('')

      container.innerHTML = `
        <nav class="flex flex-wrap gap-x-4 gap-y-1 mb-10 text-sm">${nav}</nav>
        ${sectionsHtml}
      `
    } catch (err) {
      console.error('[RaindropIoLinks]', err)
      const c = document.getElementById('raindrop-links')
      if (c) c.innerHTML = '<p class="text-gray-500 dark:text-gray-400">Failed to load links.</p>'
    }
  }

  loadLinks()
</script>