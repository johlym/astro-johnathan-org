---
interface Props {
  post: {
    slug: string;
    date: Date;
    title: string;
    excerpt?: string;
    category?: string;
  };
}

const { post } = Astro.props;
---

<article class={`group py-8 border-b border-neutral-900 transition-colors`}>
  <a href={`/blog/${post.slug}`} class="no-underline block">
    <div class="flex items-start justify-between gap-8">
      <div class="flex-1">
        <p class="text-neutral-600 text-xs mb-3 font-heading">
          {post.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
        </p>
        <h3 class="text-neutral-100 text-lg mb-3 group-hover:text-lime-400 transition-colors font-heading">
          {post.title}
        </h3>
        {post.excerpt && (
          <p class="text-neutral-500 text-sm leading-relaxed">{post.excerpt}</p>
        )}
        {post.category && (
          <div class="flex items-center gap-3 mt-4">
            <span class="text-xs text-neutral-700 bg-neutral-900 px-2 py-1">{post.category}</span>
          </div>
        )}
      </div>
      <svg class="w-5 h-5 text-neutral-700 group-hover:text-lime-400 group-hover:translate-x-1 transition-all mt-6 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path d="M4.5 12h15m0 0l-6.75-6.75M19.5 12l-6.75 6.75"></path>
      </svg>
    </div>
  </a>
</article>
  </a>
</article>