---
import { getWorkExperience } from '../lib/payload'

interface Props {
  block: {
    showAll?: boolean
    selectedExperiences?: (number | { id: number })[]
  }
}

const { block } = Astro.props

const formatDate = (iso: string) => {
  const d = new Date(iso)
  return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })
}

let experiences: Awaited<ReturnType<typeof getWorkExperience>>['docs'] = []

try {
  if (block.showAll) {
    const result = await getWorkExperience()
    experiences = result.docs
  } else {
    const ids = (block.selectedExperiences || []).map((e) =>
      typeof e === 'object' ? e.id : e,
    )
    if (ids.length) {
      const result = await getWorkExperience(ids)
      const idOrder = new Map(ids.map((id, i) => [id, i]))
      experiences = result.docs.sort(
        (a, b) => (idOrder.get(a.id) ?? 0) - (idOrder.get(b.id) ?? 0),
      )
    }
  }
} catch {
  // fallback to empty
}
---

{experiences.length > 0 && (
  <div class="space-y-4 my-8">
    <h2>Work Experience</h2>
    {experiences.map((exp) => (
      <div class="p-4 rounded-lg bg-gray-100 dark:bg-gray-800">
        <div class="font-bold">{exp.title}</div>
        <div class="text-sm text-gray-600 dark:text-gray-300">{exp.where}</div>
        <div class="text-sm text-gray-500 dark:text-gray-400 mt-1">
          {formatDate(exp.from)} – {exp.current ? 'Present' : exp.to ? formatDate(exp.to) : ''}
        </div>
        {exp.details && (
          <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">{exp.details}</p>
        )}
      </div>
    ))}
  </div>
)}
