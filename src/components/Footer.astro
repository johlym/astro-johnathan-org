---
interface Props {
  siteTitle: string
}

const { siteTitle } = Astro.props
---

<footer class="border-t border-gray-200 dark:border-gray-700 mt-auto">
  <div class="max-w-2xl mx-auto px-4 py-6 text-center text-sm text-gray-600 dark:text-gray-300">
    &copy; {new Date().getFullYear()} {siteTitle}
  </div>
</footer>
