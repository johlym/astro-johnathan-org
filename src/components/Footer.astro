---
interface Props {
  siteTitle: string
  pageStart?: number
}

const { siteTitle, pageStart } = Astro.props
const elapsed = pageStart != null ? Math.round(performance.now() - pageStart) : null
---

<footer class="w-full bg-neutral-950 border-t border-neutral-800 py-12">
  <div class="max-w-3xl mx-auto px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <div class="w-8 h-8 bg-lime-400 flex items-center justify-center">
        <span class="text-neutral-950 text-xs font-bold leading-none">J.<br />ORG</span>
      </div>
        <span class="text-neutral-500 text-xs">&copy; {new Date().getFullYear()} {siteTitle}{elapsed != null && ` · ${elapsed}ms`}</span>
      </div>
      <div class="flex items-center gap-6">
        <a href="https://github.com/johlym" class="text-neutral-600 hover:text-lime-400 transition-colors no-underline" aria-label="GitHub">
