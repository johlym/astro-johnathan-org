---
import DarkModeToggle from './DarkModeToggle.astro'

type NavLink = { href: string; label: string }

interface Props {
  siteTitle: string
  navLinks?: NavLink[]
}

const { siteTitle, navLinks = [] } = Astro.props
---

<header class="border-b border-gray-200 dark:border-gray-700">
  <nav class="max-w-2xl mx-auto px-4 py-4 flex items-center justify-between">
    <a
      href="/"
      class="text-lg font-semibold no-underline text-black dark:text-white hover:text-accent dark:hover:text-accent-light"
    >
      {siteTitle}
    </a>
    <div class="flex items-center gap-6">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm no-underline text-gray-600 dark:text-gray-300 hover:text-accent dark:hover:text-accent-light"
        >
          {link.label}
        </a>
      ))}
      <DarkModeToggle />
    </div>
  </nav>
</header>
