---
import NavLink from './NavLink.astro'

type NavLink = { href: string; label: string }

interface Props {
  siteTitle: string
  navLinks?: NavLink[]
}

const { siteTitle, navLinks = [] } = Astro.props
---

<header class="w-full bg-neutral-950 border-b border-neutral-800">
  <nav class="max-w-3xl mx-auto px-6 py-6 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3 group no-underline">
      <div class="w-8 h-8 bg-lime-400 flex items-center justify-center">
        <span class="text-neutral-950 text-xs font-bold leading-none">J.<br />ORG</span>
      </div>
      <span class="text-neutral-100 text-sm tracking-tight font-heading">{siteTitle}</span>
    </a>
    <div class="flex items-center gap-8">
      {navLinks.map((link) => (
        <NavLink href={link.href} label={link.label} />
      ))}
    </div>
  </nav>
</header>
